    `${urlBase}${profile}/4.86533989018936,52.3851812727107?contours_minutes=${minutes}&contours_colors=F1C40F&polygons=true&access_token=${mapboxgl.accessToken}`,
    { method: 'GET' }
  );
  const data28 = await query28.json();
  map.getSource('iso28').setData(data28);
}
async function getIso29() {
  const query29 = await fetch(
    `${urlBase}${profile}/4.94546542091897,52.3671603432948?contours_minutes=${minutes}&polygons=true&access_token=${mapboxgl.accessToken}`,
    { method: 'GET' }
  );
  const data29 = await query29.json();
  map.getSource('iso29').setData(data29);
}


// add markers to map
for (const feature of geojson.features) {
// create a HTML element for each feature
const el = document.createElement('div');
el.className = 'marker';
// make a marker for each feature and add it to the map
new mapboxgl.Marker(el)
.setLngLat(feature.geometry.coordinates)
.setPopup(
new mapboxgl.Popup({ offset: 25 }) // add popups
.setHTML(
`<h3>${feature.properties.title}</h3><p>${feature.properties.description}</p>`
)
)
.addTo(map);
}

